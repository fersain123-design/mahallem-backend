# PostgreSQL staging/production settings for prisma/postgres/schema.prisma
NODE_ENV=production
POSTGRES_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
POSTGRES_DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST:5432/DB_NAME?schema=public

# App runtime settings
PORT=4000
HOST=0.0.0.0
JWT_SECRET=replace-with-128-char-random-hex
LOG_LEVEL=info
OFF_API_TIMEOUT_MS=5000
BARCODE_REFRESH_TIMEOUT_MS=3000
CORS_ORIGINS=https://admin.example.com,https://seller.example.com,https://customer.example.com
