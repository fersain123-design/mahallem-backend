# Core runtime (required)
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=https://admin.example.com,https://seller.example.com,https://customer.example.com
LOG_LEVEL=info

# Queue/Redis (optional but recommended)
# If REDIS_URL is empty, backend automatically uses in-memory fallback processing.
REDIS_URL=
PRODUCT_PROCESSING_QUEUE_ENABLED=1
PRODUCT_PROCESSING_FALLBACK_ENABLED=1
PRODUCT_PROCESSING_QUEUE_BOOT_STRICT=0
PRODUCT_PROCESSING_WORKER_CONCURRENCY=2
PRODUCT_PROCESSING_JOB_TIMEOUT_MS=120000

# Barcode intelligence
BARCODE_ENABLE_OFF_FALLBACK=1
BARCODE_REFRESH_TIMEOUT_MS=10000
BARCODE_IMAGE_MIN_WIDTH=240
BARCODE_IMAGE_MIN_HEIGHT=240

# Image cleaner boot behavior (non-blocking by default)
IMAGE_CLEANER_BOOT_REQUIRED=0
IMAGE_CLEANER_BOOT_STRICT=0
IMAGE_CLEANER_BOOT_TIMEOUT_MS=20000
IMAGE_CLEANER_URL=https://image.mahallem.live/clean-image
IMAGE_CLEANER_HEALTH_URL=https://image.mahallem.live/health
IMAGE_CLEANER_AUTO_ENSURE=0
IMAGE_CLEANER_STRICT=0
IMAGE_CLEANER_ENSURE_SCRIPT=

# Product image pipeline (quality-first defaults)
PRODUCT_IMAGE_MIN_WIDTH=700
PRODUCT_IMAGE_MIN_HEIGHT=700
PRODUCT_IMAGE_QUALITY_GATE_STRICT=0
PRODUCT_IMAGE_FIDELITY_FIRST=1
PRODUCT_IMAGE_AUTO_ENHANCE_LOW_QUALITY=0
PRODUCT_IMAGE_SMART_ENHANCE_ENABLED=0
IMAGE_CLEANER_TIMEOUT_MS=120000
IMAGE_CLEANER_MAX_RETRIES=1

# Cleaner fidelity controls (conservative)
IMAGE_CLEANER_DETAIL_ALPHA_CUTOFF=180
IMAGE_CLEANER_EDGE_SOFTEN_RADIUS=0.35
IMAGE_CLEANER_OBJECT_UNSHARP_PERCENT=35
IMAGE_CLEANER_SUBJECT_AUTO_FRAME_ENABLED=0
IMAGE_CLEANER_FIDELITY_FIRST=1

# VatanSMS configuration (optional)
VATANSMS_USER=
VATANSMS_PASS=
VATANSMS_HEADER=MAHALLEM
TEST_SMS_TO=905XXXXXXXXX

# Iyzico payment configuration (optional)
IYZICO_ENABLED=true
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_CALLBACK_URL=
IYZICO_WEBHOOK_URL=
IYZICO_MERCHANT_NAME=
IYZICO_MOCK_MODE=0
PAYMENT_CURRENCY=TRY
PAYMENT_DEFAULT_LOCALE=tr
