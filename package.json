{
  "name": "mahallem-backend",
  "version": "1.0.0",
  "description": "Backend API for Mahallem - Multi-panel e-commerce platform",
  "main": "dist/server.js",
  "scripts": {
    "predev": "node scripts/ensure_port_free.js && npm run prisma:generate && node scripts/ensure_image_cleaner.js",
    "dev": "ts-node-dev --respawn --files src/server.ts",
    "seed:dev": "npx ts-node src/scripts/seedDev.ts",
    "migrate:vendor-categories:dry": "npx ts-node src/scripts/migrateVendorOwnedCategories.ts --dry-run",
    "migrate:vendor-categories": "npx ts-node src/scripts/migrateVendorOwnedCategories.ts",
    "download:neighborhoods": "npx ts-node src/scripts/downloadTurkeyNeighborhoods.ts",
    "import:neighborhoods": "npx ts-node src/scripts/importNeighborhoodsGeojson.ts",
    "ensure:admin": "node scripts/ensure_admin_user.js",
    "purge:keep-admin": "npx ts-node src/scripts/purgeUsersExcept.ts",
    "prebuild": "npm run prisma:generate",
    "build": "node ./node_modules/typescript/bin/tsc",
    "postbuild": "node scripts/copy_geojson_to_dist.js",
    "prestart": "node -e \"console.log('Using committed dist build output')\"",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "node scripts/prisma_generate_safe.js",
    "prisma:studio": "prisma studio",
    "smoke:payment:phase2": "node scripts/smoke_payment_phase2.js",
    "mail:test": "npx ts-node scripts/test_smtp_mail.ts",
    "sms:test": "node test.js"
  },
  "keywords": [
    "ecommerce",
    "nodejs",
    "express",
    "typescript",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@turf/bbox": "^7.3.4",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@types/multer": "^2.0.0",
    "axios": "^1.14.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.72.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^9.15.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4",
    "rbush": "^4.0.1",
    "sharp": "^0.34.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^7.0.11",
    "@types/rbush": "^4.0.0",
    "prisma": "^6.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
